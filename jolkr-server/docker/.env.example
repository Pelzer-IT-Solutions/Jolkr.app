# =============================================================================
# Jolkr — Environment Variables
# =============================================================================
# Copy this file to .env and fill in production values.
# Default values are suitable for local development only.
# =============================================================================

# -----------------------------------------------------------------------------
# General
# -----------------------------------------------------------------------------
# Rust log level: trace, debug, info, warn, error
RUST_LOG=info

# -----------------------------------------------------------------------------
# PostgreSQL
# -----------------------------------------------------------------------------
POSTGRES_PASSWORD=jolkr_dev
DATABASE_URL=postgres://jolkr:jolkr_dev@postgres:5432/jolkr

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_URL=redis://redis:6379

# -----------------------------------------------------------------------------
# MinIO (S3-compatible object storage)
# -----------------------------------------------------------------------------
MINIO_ROOT_USER=jolkr
MINIO_ROOT_PASSWORD=jolkr_dev_secret
MINIO_URL=http://minio:9000
MINIO_BUCKET=jolkr-uploads

# -----------------------------------------------------------------------------
# NATS (messaging / event bus)
# -----------------------------------------------------------------------------
NATS_URL=nats://nats:4222

# -----------------------------------------------------------------------------
# Authentication
# -----------------------------------------------------------------------------
# IMPORTANT: Change this to a strong random secret in production!
JWT_SECRET=super_secret_dev_key_change_in_production

# Access token lifetime (e.g., 15m, 1h)
ACCESS_TOKEN_EXPIRY=15m

# Refresh token lifetime (e.g., 7d, 30d)
REFRESH_TOKEN_EXPIRY=7d

# -----------------------------------------------------------------------------
# Media Server (WebRTC)
# -----------------------------------------------------------------------------
MEDIA_HOST=0.0.0.0
MEDIA_PORT=8081
STUN_SERVER=stun:stun.l.google.com:19302

# -----------------------------------------------------------------------------
# API Server
# -----------------------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8080
API_WORKERS=4
