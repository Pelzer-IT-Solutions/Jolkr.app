# ══════════════════════════════════════════════════════════════════════════════
# Jolkr HA Cluster — Environment Template
# Copy to .env on each node and fill in the values.
# ══════════════════════════════════════════════════════════════════════════════

# ── Node identity ────────────────────────────────────────────────────────────
# Which node is this? (node-a, node-b, node-c)
NODE_NAME=node-a
# This node's LAN IP (reachable by other nodes)
NODE_IP=192.168.1.10

# ── Cluster peers ────────────────────────────────────────────────────────────
NODE_A_IP=192.168.1.10
NODE_B_IP=192.168.1.11
NODE_C_IP=192.168.1.12

# ── Virtual IP (keepalived) ──────────────────────────────────────────────────
# Floating IP that clients connect to — moves between Node A and Node B
VIRTUAL_IP=192.168.1.100
VIRTUAL_IP_MASK=24
KEEPALIVED_PASSWORD=changeme_keepalived
# Network interface name on the host (check with `ip a`)
KEEPALIVED_INTERFACE=eth0

# ── Postgres (Patroni) ──────────────────────────────────────────────────────
POSTGRES_USER=jolkr
POSTGRES_PASSWORD=changeme_postgres
POSTGRES_DB=jolkr
REPLICATION_USER=replicator
REPLICATION_PASSWORD=changeme_replication
PATRONI_RESTAPI_PASSWORD=changeme_patroni

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=changeme_redis

# ── NATS ─────────────────────────────────────────────────────────────────────
NATS_USER=jolkr_api
NATS_PASSWORD=changeme_nats
NATS_HMAC_SECRET=changeme_hmac_min_32_chars_long_here
NATS_CLUSTER_PASSWORD=changeme_nats_cluster

# ── MinIO ────────────────────────────────────────────────────────────────────
MINIO_ROOT_USER=jolkr
MINIO_ROOT_PASSWORD=changeme_minio

# ── Jolkr API ───────────────────────────────────────────────────────────────
JWT_SECRET=changeme_jwt_secret_64_chars_minimum
ADMIN_SECRET=changeme_admin
VAPID_PRIVATE_KEY=
VAPID_PUBLIC_KEY=
VAPID_SUBJECT=mailto:admin@jolkr.app
PUBLIC_IP=your.public.ip.here
APP_URL=https://jolkr.app/app
CORS_ORIGINS=https://jolkr.app,https://tauri.localhost

# ── SMTP ─────────────────────────────────────────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_FROM=noreply@jolkr.app
SMTP_USER=
SMTP_PASSWORD=

# ── TLS ──────────────────────────────────────────────────────────────────────
# Place fullchain.pem and privkey.pem in ./certs/ on each node
# For Let's Encrypt, use certbot or acme.sh

# ── External services ───────────────────────────────────────────────────────
CLOUDFLARE_API_TOKEN=
RUST_LOG=info
