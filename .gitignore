# =============================================================================
# Jolkr Project — .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# Rust
# -----------------------------------------------------------------------------
**/target/
**/*.rs.bk
*.pdb

# -----------------------------------------------------------------------------
# IDE / Editors
# -----------------------------------------------------------------------------
.idea/
.vscode/
*.iml
*.swp
*.swo
*~

# -----------------------------------------------------------------------------
# Docker / Environment
# -----------------------------------------------------------------------------
.env
!.env.example
docker-compose.override.yml

# TLS certificates (never commit real certs)
**/certs/*.pem
**/certs/*.key
**/certs/*.crt

# -----------------------------------------------------------------------------
# OS generated files
# -----------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
Thumbs.db
ehthumbs.db
Desktop.ini

# -----------------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------------
*.log
logs/

# -----------------------------------------------------------------------------
# Node / Web
# -----------------------------------------------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
dist/
dist-tauri/

# -----------------------------------------------------------------------------
# Signing keys (private key — NEVER commit)
# -----------------------------------------------------------------------------
keys/jolkr-update.key
keys/android-keystore.jks

# -----------------------------------------------------------------------------
# Cargo workaround (ESET Controlled Folder Access)
# -----------------------------------------------------------------------------
.cargo-home/

# -----------------------------------------------------------------------------
# Miscellaneous
# -----------------------------------------------------------------------------
*.bak
*.tmp
*.orig

icons.py
.claude
